generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── App models ───

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
}

model FormSubmission {
  id         String   @id @default(cuid())
  tipo       String
  nombre     String
  email      String
  telefono   String?
  empresa    String?
  sector     String?
  mensaje    String
  estado     String   @default("nuevo")
  notas      String?
  syncMautic Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tipo])
  @@index([estado])
  @@index([createdAt(sort: Desc)])
  @@index([tipo, estado])
}

model PipelineLead {
  id              String    @id @default(cuid())
  nombre          String
  empresa         String?
  email           String?
  telefono        String?
  origen          String?
  etapa           String    @default("lead")
  notas           String?
  ultimoContacto  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([etapa])
  @@index([updatedAt(sort: Desc)])
}

model PilotoSubmission {
  id               String   @id @default(cuid())
  nombre           String
  cargo            String
  municipio        String
  zonas            Json     @default("[]")
  interesesControl Json     @default("[]")
  estado           String   @default("nuevo")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model DossierDownload {
  id        String   @id @default(cuid())
  ip        String
  country   String?
  locale    String
  createdAt DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([country])
  @@index([ip])
}
